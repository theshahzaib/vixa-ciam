# Copy to .env and adjust. In production, secrets come from the secrets vault,
# never from a committed file. All variables are prefixed VIXA_.

VIXA_ENVIRONMENT=development

# --- JWT / token strategy ---
# Generate a strong value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
VIXA_JWT_SECRET=dev-only-change-me-in-the-secrets-vault
VIXA_ACCESS_TOKEN_TTL_SECONDS=900
VIXA_REFRESH_TOKEN_TTL_SECONDS=1209600

# --- Rate limiting ---
VIXA_RATE_LIMIT_PER_MINUTE=240
VIXA_SENSITIVE_RATE_LIMIT_PER_MINUTE=40

# --- MFA / OTP ---
VIXA_OTP_TTL_SECONDS=300
VIXA_OTP_LENGTH=6

# --- Payments ---
VIXA_PAYMENT_HOLD_AMOUNT_CENTS=100
VIXA_PAYMENT_HOLD_CURRENCY=EUR
VIXA_PAYMENT_HOLD_DAYS=3

# --- CORS (the SPA origin) ---
# VIXA_CORS_ORIGINS=["http://localhost:5173"]
